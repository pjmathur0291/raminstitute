# MongoDB
MONGO_URL="mongodb://localhost:27017"
DB_NAME="rihm_production"

# CORS — set to your production domain(s) comma-separated
CORS_ORIGINS="https://www.raminstitute.in,https://raminstitute.in"

# JWT — generate a NEW one: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING"

# Admin login — CHANGE the password in production!
ADMIN_EMAIL="admin@ram.institute"
ADMIN_PASSWORD="CHANGE_ME_TO_STRONG_PASSWORD"
ADMIN_NAME="RIHM Admin"

# Email (Gmail SMTP) — get app password from https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="admissions.raminstitute@gmail.com"
SMTP_PASSWORD=""
SENDER_EMAIL="admissions.raminstitute@gmail.com"
SENDER_NAME="RIHM Admissions"
NOTIFY_EMAIL="admissions.raminstitute@gmail.com,tanishk@raminstitute.in"

# Optional fallback: Resend (https://resend.com)
RESEND_API_KEY=""

# WhatsApp via Twilio (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
NOTIFY_WHATSAPP="whatsapp:+917055547000"

# Razorpay (https://dashboard.razorpay.com)
# Test mode: rzp_test_*  |  Live mode: rzp_live_*
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
APPLICATION_FEE_INR=5000
