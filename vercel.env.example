# Vercel Environment Variables
# Copy each key into: Vercel Dashboard → Project → Settings → Environment Variables
# Apply to: Production, Preview, and Development
# NEVER commit real values to Git — only this template.

# --- MongoDB Atlas (required) ---
# Use your Atlas SRV string — on Vercel it is auto-converted to a standard mongodb:// URI.
# IMPORTANT: password must match Atlas Database Access (rotate if unsure).
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
# If SRV still fails on Vercel, paste the Standard connection string from Atlas instead:
# MONGO_URL=mongodb://USER:PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
DB_NAME=rihm_local

# --- Auth (required) ---
JWT_SECRET=generate_with_openssl_rand_hex_32
ADMIN_EMAIL=admin@ram.institute
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_NAME=RIHM Admin

# --- CORS — add your Vercel URL + custom domain ---
CORS_ORIGINS=https://your-project.vercel.app,https://www.raminstitute.in,https://raminstitute.in

# --- Frontend build (leave empty for same-domain /api on Vercel) ---
REACT_APP_BACKEND_URL=

# --- Email (optional but recommended) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admissions.raminstitute@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SENDER_EMAIL=admissions.raminstitute@gmail.com
SENDER_NAME=RIHM Admissions
NOTIFY_EMAIL=admissions.raminstitute@gmail.com,tanishk@raminstitute.in

# --- ExtraaEdge CRM (optional) ---
EXTRAEEDGE_WEBHOOK_URL=https://eeintegration.extraaedge.com/api/integration/Fru3LCCmak2EA8CM
# Optional fallback when a form does not send its own source tag
# EXTRAEEDGE_SOURCE=website

# --- Razorpay (required for /apply payments) ---
# Get keys from https://dashboard.razorpay.com/app/keys
# Test: rzp_test_* + secret  |  Live (real money): rzp_live_* + secret after KYC
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
APPLICATION_FEE_INR=5000

# --- WhatsApp via Twilio (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NOTIFY_WHATSAPP=whatsapp:+917055547000

# --- Resend email fallback (optional) ---
RESEND_API_KEY=
