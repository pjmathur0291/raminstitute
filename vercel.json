{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "create-react-app"
    },
    "backend": {
      "entrypoint": "api/index.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "maxDuration": 30,
      "excludeFiles": "{frontend/**,backend/tests/**,backend/venv/**,backend/memory/**,**/*.test.py,**/test_*.py}"
    }
  }
}
